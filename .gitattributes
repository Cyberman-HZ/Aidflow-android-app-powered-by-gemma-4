# Normalize all text files to LF in the repository.
# Avoids the "LF will be replaced by CRLF" warnings on Windows clones.
* text=auto eol=lf

# Source / config files — always LF
*.kt        text eol=lf
*.kts       text eol=lf
*.java      text eol=lf
*.xml       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.gradle    text eol=lf
*.properties text eol=lf
*.pro       text eol=lf
*.txt       text eol=lf
gradlew     text eol=lf

# Windows-only scripts — keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binaries — never touched
*.png       binary
*.jpg       binary
*.jpeg      binary
*.webp      binary
*.gif       binary
*.ico       binary
*.jar       binary
*.apk       binary
*.aab       binary
*.litertlm  binary
*.task      binary
*.pdf       binary
*.docx      binary
*.xlsx      binary
*.zip       binary
